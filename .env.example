# Copy to .env locally if official DSV Developer API is added later.
# Do not commit .env.

# Destination aliases used by DGF, DSV, and Maersk to pick the Shanghai arrival leg.
SHIPMENT_DESTINATION_ALIASES=SHANGHAI,PVG,SHA,CNSHA

DSV_TRACKING_SUBSCRIPTION_KEY=
DSV_ACCESS_TOKEN_SUBSCRIPTION_KEY=
DSV_CLIENT_ID=
DSV_CLIENT_SECRET=
DSV_TOKEN_URL=https://api.dsv.com/my/oauth/v1/token
DSV_API_BASE_URL=https://api.dsv.com/my/tracking/v2

# DGF tracking via DHL Shipment Tracking - Unified API.
# This key is only for rows where 货代 = DGF, not DHL EXPRESS.
DGF_API_KEY=
DGF_API_SECRET=
DGF_API_BASE_URL=https://api-eu.dhl.com/track
# Backward compatible fallback if SHIPMENT_DESTINATION_ALIASES is not set.
DGF_DESTINATION_ALIASES=SHANGHAI,PVG,SHA,CNSHA

# Maersk Developer Portal Track & Trace Events API.
# Fill these after the Maersk app/subscription is approved.
MAERSK_CONSUMER_KEY=
MAERSK_CONSUMER_SECRET=
MAERSK_CUSTOMER_KEY=
MAERSK_TOKEN_URL=https://api.maersk.com/customer-identity/oauth/v2/access_token
MAERSK_API_BASE_URL=https://api.maersk.com/track-and-trace-private
MAERSK_EVENTS_PATH=/events
